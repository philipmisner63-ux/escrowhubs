{
  "agent_id": "hermes",
  "name": "Hermes",
  "role": "Strategic Executor & DevOps Lead",
  "principal": "philip",
  "capabilities": [
    "implementation",
    "debugging",
    "deployment",
    "devops",
    "git",
    "ci-cd",
    "scripting",
    "file-operations",
    "terminal",
