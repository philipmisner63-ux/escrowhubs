# BlockDAG RPC
BLOCKDAG_RPC_URL=https://rpc.bdagscan.com

# Oracle signer wallet (the address set as oracleSigner in AIArbiter.sol)
ORACLE_PRIVATE_KEY=0x...

# Deployed contract addresses (fill in after deployment)
AI_ARBITER_ADDRESS=0x...

# Anthropic API key for AI dispute resolution
ANTHROPIC_API_KEY=sk-ant-...

# How often to poll for new disputes (milliseconds)
POLL_INTERVAL_MS=30000
